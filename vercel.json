{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "rewrites": [
    {
      "source": "/:key([a-f0-9]{32}).txt",
      "destination": "/api/indexnow-key/:key"
    },
    {
      "source": "/llms.txt",
      "destination": "/api/llms"
    },
    {
      "source": "/llms-full.txt",
      "destination": "/api/llms?full=1"
    }
  ]
}